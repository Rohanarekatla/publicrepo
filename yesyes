from azure.devops.connection import Connection
from azure.devops.credentials import BasicAuthentication
from msrest.authentication import BasicAuthentication
from datetime import datetime
import sys

def get_pool_id_by_name(client, pool_name):
    """
    Get the pool ID from Azure DevOps using the pool name.
    
    Args:
        client: Azure DevOps Task Agent client
        pool_name (str): Name of the agent pool
    
    Returns:
        int: Pool ID if found, None otherwise
    """
    try:
        # Get all agent pools
        pools = client.get_agent_pools()
        
        # Find the pool with matching name
        for pool in pools:
            if pool.name.lower() == pool_name.lower():
                return pool.id
        
        print(f"\nNo pool found with name: {pool_name}")
        print("Available pools:")
        for pool in pools:
            print(f"- {pool.name}")
        return None
        
    except Exception as e:
        print(f"Error getting pool information: {str(e)}")
        return None

def get_inactive_agents(client, pool_id):
    """
    Get all inactive agents from a specific agent pool in Azure DevOps.
    
    Args:
        client: Azure DevOps Task Agent client
        pool_id (int): Agent pool ID
    
    Returns:
        list: List of inactive agents with their details
    """
    try:
        # Get all agents in the pool
        agents = client.get_agents(pool_id)
        
        # Filter for inactive agents
        inactive_agents = []
        for agent in agents:
            if not agent.enabled or agent.status != "online":
                inactive_agents.append(agent)
        
        return inactive_agents
    
    except Exception as e:
        print(f"Error getting agents: {str(e)}")
        return None

def main():
    # Configuration
    organization_url = "https://dev.azure.com/your-organization"  # Replace with your organization URL
    personal_access_token = "your-pat-token"                      # Replace with your PAT token
    pool_name = "your-pool-name"                                 # Replace with your pool name
    
    try:
        # Create a connection to Azure DevOps
        credentials = BasicAuthentication('', personal_access_token)
        connection = Connection(base_url=organization_url, creds=credentials)
        
        # Get the task agent client
        task_agent_client = connection.clients.get_task_agent_client()
        
        # Get pool ID from name
        pool_id = get_pool_id_by_name(task_agent_client, pool_name)
        
        if not pool_id:
            print("Could not proceed without pool ID.")
            return
        
        print(f"Found pool ID: {pool_id} for pool name: {pool_name}")
        
        # Get inactive agents
        inactive_agents = get_inactive_agents(task_agent_client, pool_id)
        
        if inactive_agents:
            print(f"\nFound {len(inactive_agents)} inactive agents:")
            print("-" * 50)
            for agent in inactive_agents:
                last_seen = datetime.fromisoformat(agent.created_on.replace('Z', '+00:00')) if agent.created_on else None
                print(f"Name: {agent.name}")
                print(f"ID: {agent.id}")
                print(f"Status: {agent.status}")
                print(f"Enabled: {agent.enabled}")
                print(f"Last Seen: {last_seen}")
                print(f"Version: {agent.version}")
                print(f"OS Description: {agent.os_description}")
                print(f"Provisioning State: {agent.provisioning_state}")
                print("-" * 50)
        else:
            print("No inactive agents found or error occurred.")
    
    except Exception as e:
        print(f"An unexpected error occurred: {str(e)}")
        print("\nTroubleshooting steps:")
        print("1. Make sure you have installed the azure-devops package:")
        print("   pip install azure-devops")
        print("2. Verify your Personal Access Token has the correct permissions:")
        print("   - Agent Pools (Read)")
        print("   - Build (Read)")
        print("3. Check that your organization URL is correct")

if __name__ == "__main__":
    main()