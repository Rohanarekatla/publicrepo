for /f %i in ('az account list --query "[].id" -o tsv') do @(az account set --subscription %i > nul && az resource list --name YOUR-VNET-NAME --resource-type "Microsoft.Network/virtualNetworks" --query "[].{Subscription:subscriptionId, ResourceGroup:resourceGroup, Name:name, AddressSpace:properties.addressSpace.addressPrefixes[]}" -o table 2>nul)