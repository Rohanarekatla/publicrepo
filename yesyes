def get_default_app_role(app):
    """
    Get the default app role ID or User role ID
    """
    app_roles = app.get('appRoles', [])
    
    # First, try to find the User role
    user_role = next((role for role in app_roles if role.get('value') == 'User'), None)
    if user_role:
        return user_role['id']
        
    # If no User role, get the first enabled role
    default_role = next((role for role in app_roles if role.get('isEnabled', True)), None)
    if default_role:
        return default_role['id']
        
    # If no roles defined, return the default User role ID
    return '00000000-0000-0000-0000-000000000000'

def add_group_to_app(access_token, sp_id, group_id, app):
    """
    Add group to the application using proper app role assignment
    """
    graph_url = f"https://graph.microsoft.com/v1.0/groups/{group_id}/appRoleAssignments"
    headers = {
        'Authorization': f'Bearer {access_token}',
        'Content-Type': 'application/json'
    }
    
    # Get the appropriate role ID
    app_role_id = get_default_app_role(app)
    
    data = {
        "principalId": group_id,
        "resourceId": sp_id,
        "appRoleId": app_role_id
    }
    
    try:
        response = requests.post(graph_url, headers=headers, json=data)
        response.raise_for_status()
        
        # Wait a moment and verify the assignment
        time.sleep(2)
        if check_group_assignment(access_token, sp_id, group_id):
            return True
        else:
            print("Assignment was not verified after creation")
            return False
            
    except requests.exceptions.RequestException as e:
        print(f"Error adding group: {str(e)}")
        if hasattr(e.response, 'text'):
            print(f"Response content: {e.response.text}")
        return False

